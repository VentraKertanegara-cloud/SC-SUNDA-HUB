-- [[ 🤖 ENJIN AUTO-INTERACT (AUTO-E) ]] --
local function StartAutoE()
    TrackerFrame.Visible = true
    UpdateTracker()
    
    task.spawn(function()
        while _G.Settings.AutoFarm do
            task.wait(0.25) -- Kelajuan imbasan bahan
            pcall(function()
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                
                for _, obj in pairs(workspace:GetDescendants()) do
                    for name, info in pairs(Inventory) do
                        if string.find(obj.Name, name) and info.count < _G.Settings.TargetLimit then
                            local part = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")
                            
                            if part and (hrp.Position - part.Position).Magnitude < _G.Settings.CollectDistance then
                                local prompt = obj:FindFirstChildOfClass("ProximityPrompt") or part:FindFirstChildOfClass("ProximityPrompt")
                                
                                if prompt and prompt.Enabled then
                                    -- SISTEM TEKAN E SECARA AUTOMATIK
                                    prompt.HoldDuration = 0 -- Bypass masa tekan lama
                                    fireproximityprompt(prompt) -- Fungsi simulasi tekan E
                                    
                                    info.count = info.count + 1
                                    UpdateTracker()
                                    task.wait(0.4) -- Jeda keselamatan anti-kick
                                end
                            end
                        end
                    end
                end
            end)
        end
    end)
end

-- [[ VERIFIKASI LOGIN ]] --
ActionBtn.MouseButton1Click:Connect(function()
    local userK = KeyInput.Text
    local userL = tonumber(LimitInput.Text) or 10
    
    ActionBtn.Text = "MENYAMBUNG..."
    
    local success, data = pcall(function() return game:HttpGet(_G.Settings.DatabaseURL) end)
    
    if success and string.find(data, userK .. ":" .. HWID) then
        _G.Settings.TargetLimit = math.clamp(userL, 1, 100)
        _G.Settings.AutoFarm = true
        ActionBtn.Text = "✅ AUTO-E AKTIF"
        ActionBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        
        task.wait(1.5)
        MainFrame:TweenPosition(UDim2.new(0.5, -180, -0.7, 0), "In", "Back", 0.7)
        StartAutoE()
    else
        ActionBtn.Text = "❌ KUNCI SALAH"
        ActionBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        task.wait(2)
        ActionBtn.Text = "LOGIN & AUTO-E"
        ActionBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    end
end)

